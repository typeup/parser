{
	"name": "@typeup/parser",
	"version": "1.2.5-beta.1",
	"description": "Parser for TypeUp documents with a simple event-based API.",
	"author": "Simon Mika <simon@mika.se>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/typeup/parser.git"
	},
	"bugs": {
		"url": "https://github.com/typeup/parser/issues"
	},
	"homepage": "https://github.com/typeup/parser",
	"private": false,
	"type": "module",
	"types": "./dist/types/index.d.ts",
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"git": {
		"tagName": "release-${version}"
	},
	"github": {
		"release": true
	},
	"scripts": {
		"lint": "biome format .",
		"format": "biome format --write .",
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest --run",
		"coverage": "vitest --coverage",
		"clean": "rimraf dist node_modules coverage",
		"verify": "npm run build && npm run test && npm run lint && npm audit --omit=dev"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@vitest/coverage-v8": "4.1.5",
		"rimraf": "6.1.3",
		"typescript": "6.0.3",
		"vite": "8.0.10",
		"vitest": "4.1.5"
	},
	"dependencies": {
		"@typeup/dom": "^1.0.11-beta.3",
		"mendly": "^3.1.1-beta.16"
	}
}
