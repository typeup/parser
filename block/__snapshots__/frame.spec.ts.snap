// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`parser.block.frame > !frame https://example.com/page.html
Frame caption. - with-source 1`] = `
[
  {
    "class": "block.frame",
    "classes": [],
    "content": [
      {
        "class": "inline.text",
        "value": "Frame caption.",
      },
    ],
    "source": "https://example.com/page.html",
  },
]
`;

exports[`parser.block.frame > !frame https://example.com/page.html classA classB
Frame caption. - with-classes 1`] = `
[
  {
    "class": "block.frame",
    "classes": [
      "classA",
      "classB",
    ],
    "content": [
      {
        "class": "inline.text",
        "value": "Frame caption.",
      },
    ],
    "source": "https://example.com/page.html",
  },
]
`;
